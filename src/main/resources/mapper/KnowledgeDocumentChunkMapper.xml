<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.yifan.drawsee.mapper.KnowledgeDocumentChunkMapper">

    <resultMap id="KnowledgeDocumentChunkResultMap" type="cn.yifan.drawsee.pojo.entity.KnowledgeDocumentChunk">
        <id property="id" column="id"/>
        <result property="documentId" column="document_id"/>
        <result property="knowledgeBaseId" column="knowledge_base_id"/>
        <result property="chunkIndex" column="chunk_index"/>
        <result property="content" column="content"/>
        <result property="tokenCount" column="token_count"/>
        <result property="vectorId" column="vector_id"/>
        <result property="vectorDimension" column="vector_dimension"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <insert id="insertBatch">
        INSERT INTO knowledge_document_chunk (
            id,
            document_id,
            knowledge_base_id,
            chunk_index,
            content,
            token_count,
            vector_id,
            vector_dimension,
            created_at,
            updated_at
        ) VALUES
        <foreach collection="chunks" item="item" separator=",">
            (
                #{item.id},
                #{item.documentId},
                #{item.knowledgeBaseId},
                #{item.chunkIndex},
                #{item.content},
                #{item.tokenCount},
                #{item.vectorId},
                #{item.vectorDimension},
                #{item.createdAt},
                #{item.updatedAt}
            )
        </foreach>
    </insert>

    <select id="listByDocumentId" resultMap="KnowledgeDocumentChunkResultMap">
        SELECT *
        FROM knowledge_document_chunk
        WHERE document_id = #{documentId}
        ORDER BY chunk_index ASC
    </select>

    <delete id="deleteByDocumentId">
        DELETE FROM knowledge_document_chunk WHERE document_id = #{documentId}
    </delete>

    <select id="countByKnowledgeBaseId" resultType="int">
        SELECT COUNT(1)
        FROM knowledge_document_chunk
        WHERE knowledge_base_id = #{knowledgeBaseId}
    </select>

</mapper>
