<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="cn.yifan.drawsee.mapper.AdminMapper">

    <select id="getByUserId"
            parameterType="long"
            resultType="cn.yifan.drawsee.pojo.entity.Admin"
    >
        SELECT id, user_id
        FROM admin
        WHERE user_id = #{userId}
    </select>

    <insert id="insert"
            parameterType="cn.yifan.drawsee.pojo.entity.Admin"
            useGeneratedKeys="true"
            keyProperty="id"
    >
        INSERT INTO admin (user_id) VALUES (#{userId})
    </insert>

</mapper>