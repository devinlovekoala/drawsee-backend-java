server:
  port: 6868

management: # 开启监控
  endpoints:
    web:
      exposure:
        include: "*"

logging:
  level:
    cn.yifan.drawsee.mapper : debug
    cn.yifan.drawsee.worker : info

sa-token:
  # token 名称（同时也是 cookie 名称）
  token-name: Authorization
  # token 有效期（单位：秒） 默认30天，-1 代表永久有效
  timeout: 2592000
  # token 最低活跃频率（单位：秒），如果 token 超过此时间没有访问系统就会被冻结，默认-1 代表不限制，永不冻结
  active-timeout: -1
  # 是否允许同一账号多地同时登录 （为 true 时允许一起登录, 为 false 时新登录挤掉旧登录）
  is-concurrent: true
  # 在多人登录同一账号时，是否共用一个 token （为 true 时所有登录共用一个 token, 为 false 时每次登录新建一个 token）
  is-share: true
  # token 风格（默认可取值：uuid、simple-uuid、random-32、random-64、random-128、tik）
  token-style: uuid
  # 是否输出操作日志
  is-log: true
  # token前缀
  token-prefix: Bearer

drawsee:
  mysql:
    driver-class-name: com.mysql.cj.jdbc.Driver
    host: ${MYSQL_HOST:localhost}
    port: ${MYSQL_PORT:3306}
    database: ${MYSQL_DATABASE:drawsee}
    username: ${MYSQL_USERNAME:root}
    password: ${MYSQL_PASSWORD:your_mysql_password}
  minio:
    endpoint: ${MINIO_ENDPOINT:http://localhost:9000}
    accessKey: ${MINIO_ACCESS_KEY:your_minio_access_key}
    secretKey: ${MINIO_SECRET_KEY:your_minio_secret_key}
    bucketName: ${MINIO_BUCKET:drawsee}
  models:
    qwen:
      baseUrl: ${QWEN_BASE_URL:https://dashscope.aliyuncs.com/compatible-mode/v1}
      apiKey: ${QWEN_API_KEY:your_qwen_api_key}
      modelName: ${QWEN_MODEL_NAME:qwen3.5-plus}
      temperature: 0.7
      customParameters:
        enable_thinking: false
    deepseekV3:
      baseUrl: ${DEEPSEEK_BASE_URL:https://api.siliconflow.cn/v1}
      apiKey: ${DEEPSEEK_API_KEY:your_deepseek_api_key}
      modelName: ${DEEPSEEK_MODEL_NAME:deepseek-ai/DeepSeek-V3.2}
      customParameters:
        enable_thinking: false
    qwenVision:
      baseUrl: ${SILICONFLOW_BASE_URL:https://api.siliconflow.cn/v1}
      apiKey: ${SILICONFLOW_API_KEY:your_siliconflow_api_key}
      modelName: ${QWEN_VISION_MODEL_NAME:Pro/moonshotai/Kimi-K2.5}
      temperature: 0.1
      customParameters:
        enable_thinking: false
    compress:
      baseUrl: ${SILICONFLOW_BASE_URL:https://api.siliconflow.cn/v1}
      apiKey: ${SILICONFLOW_API_KEY:your_siliconflow_api_key}
      modelName: ${COMPRESS_MODEL_NAME:deepseek-ai/DeepSeek-R1-Distill-Qwen-14B}
      temperature: 0.2
    embedding:
      baseUrl: ${EMBEDDING_BASE_URL:https://api.siliconflow.cn/v1/embeddings}
      apiKey: ${EMBEDDING_API_KEY:your_embedding_api_key}
      modelName: ${EMBEDDING_MODEL:Qwen/Qwen3-Embedding-8B}
  # Web搜索配置（用于查询电子元器件资料）
  search:
    enabled: ${SEARCH_ENABLED:true}
    api-key: ${SEARCH_API_KEY:your_baidu_appbuilder_api_key}
  # Python微服务配置
  python-service:
    base-url: ${PYTHON_SERVICE_URL:http://localhost:8000}
    timeout: 60000
    enabled: false
  # RAG入库流程配置
  rag-ingestion:
    mode: JAVA  # JAVA / PYTHON
    batch-size: 64
  # RAG检索流程配置
  rag-query:
    mode: JAVA  # JAVA / PYTHON
    top-k: 5
    max-context-tokens: 160000
    safe-input-ratio: 0.65
    reserved-output-tokens: 8000
    history-ratio: 0.30
    retrieval-ratio: 0.45
    max-chunks-in-context: 4
    rag-timeout-ms: 1200
  # Qdrant向量库配置
  qdrant:
    host: ${QDRANT_HOST:localhost}
    port: ${QDRANT_PORT:6333}
    api-key: ${QDRANT_API_KEY:}
    https: ${QDRANT_HTTPS:false}
    collection: ${QDRANT_COLLECTION:circuit_embeddings}
  # 内部服务JWT配置
  internal-jwt:
    secret: ${INTERNAL_JWT_SECRET:your-super-secret-key-min-32-chars-change-in-production}
    expiration: 3600
  rabbitmq:
    aiConfig:
      exchangeName: direct_ai_task_exchange
      queueName: direct_ai_task_queue
      routingKey: ai_task
      queueCount: 5
    animationConfig:
      exchangeName: direct_animation_task_exchange
      queueName: direct_animation_task_queue
      routingKey: animation_task
      queueCount: 3

spring:
  application:
    name: drawsee-java
  profiles:
    active: prod
  mail:
    host: smtp.qq.com
    protocol: smtp
    default-encoding: UTF-8
    username: ${MAIL_USERNAME:your_email@qq.com}
    password: ${MAIL_PASSWORD:your_smtp_authorization_code}
    test-connection: true
    properties:
      mail:
        smtp:
          auth: true
          starttls:
            enable: true
            required: true
  thymeleaf:
    cache: false
    prefix: classpath:/templates/
    encoding: UTF-8
    suffix: .html
    mode: HTML
  servlet:
    multipart:
      enabled: true
      max-file-size: 50MB
      max-request-size: 100MB
      file-size-threshold: 2KB
      location: ${java.io.tmpdir}
      resolve-lazily: false
  rabbitmq:
    host: ${RABBITMQ_HOST:localhost}
    port: ${RABBITMQ_PORT:5672}
  datasource:
    druid:
      driver-class-name: ${drawsee.mysql.driver-class-name}
      url: jdbc:mysql://${drawsee.mysql.host}:${drawsee.mysql.port}/${drawsee.mysql.database}?serverTimezone=Asia/Shanghai&useUnicode=true&characterEncoding=utf-8&zeroDateTimeBehavior=convertToNull&useSSL=false&allowPublicKeyRetrieval=true
      username: ${drawsee.mysql.username}
      password: ${drawsee.mysql.password}
  data:
    redis:
      host: ${REDIS_HOST:localhost}
      port: ${REDIS_PORT:6379}
      # 连接超时时间
      timeout: 10s
      lettuce:
        pool:
          max-active: 200
          max-wait: -1ms
          max-idle: 10
          min-idle: 0

# RAG配置
rag:
  chunk-size: ${RAG_CHUNK_SIZE:800}
  chunk-overlap: ${RAG_CHUNK_OVERLAP:200}

mybatis:
  mapper-locations: classpath*:mapper/*.xml
  type-aliases-package: cn.yifan.drawsee.pojo.entity
  configuration:
    map-underscore-to-camel-case: true
